---
import MainLayout from '../layouts/MainLayout.astro';

const s3BookingUrl = 'https://example.com/s3-terminvergabe';

const leitbild = [
  {
    title: 'Drei Generationen, eine Praxis',
    text: 'Manche unserer Patientinnen und Patienten kennen wir, seit sie selbst noch Kinder waren – und behandeln inzwischen schon ihre eigenen Kinder oder Enkel. Wir sehen nicht nur Befunde und Werte, sondern Menschen mit einer Geschichte. Wer zu uns kommt, muss nicht immer alles von Anfang an erzählen – wir wissen oft schon, woher jemand kommt und was ihn beschäftigt.'
  },
  {
    title: 'Vertrauen, das über Jahre wächst',
    text: 'Diese Verbindung über Generationen hinweg ist für uns eine Verantwortung, die wir ernst nehmen. Sie bedeutet, dass wir uns Zeit nehmen, zuhören und nachfragen – auch dann, wenn ein Termin eng getaktet ist. Gleichzeitig bleiben wir fachlich auf dem aktuellen Stand, bilden uns regelmäßig fort und passen unsere Abläufe an, wenn wir merken, dass es besser geht.'
  },
  {
    title: 'Miteinander statt nebeneinander',
    text: 'Eine Praxis mit langer Geschichte lebt von einem Team, das zusammenhält. Wir gehen offen miteinander um, unterstützen uns gegenseitig und sprechen Probleme an, statt sie zu verschweigen. Nur so können wir die Qualität halten, die unsere Patientinnen und Patienten seit Jahrzehnten von uns erwarten.'
  },
  {
    title: 'Erreichbar, wenn es zählt',
    text: 'Gerade bei dringenden Anliegen wissen unsere Patientinnen und Patienten: Hier werden wir gehört. Wir sind gut erreichbar, bemühen uns um zeitnahe Termine und finden auch kurzfristig eine Lösung, wenn es nötig ist.'
  }
];

const leistungen = [
  'Laboruntersuchungen',
  'EKG',
  'Langzeit-Blutdruckmessung',
  'Spirometrie',
  'Schellong-Test',
  'Impfungen',
  'Wundversorgung',
  'Ohrspülung',
  'U-Untersuchungen',
  'Gesundheitsuntersuchung (Check-up 35)',
  'Hautkrebs-Screening',
  'Vorsorge für Männer ab 45 Jahre',
  'DMP Diabetes mellitus',
  'Präoperative Untersuchungen',
  'Jugendschutzuntersuchung',
  'Führerscheinuntersuchung',
  'Psychosomatische Grundversorgung',
  'Reset-Therapie'
];

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const aerzte = [
  {
    name: 'Dr. med. B. Schilling',
    image: `${baseUrl}images/team/dr-schilling.jpg`,
    imagePosition: 'object-top'
  },
  {
    name: 'J. Osmaston',
    image: `${baseUrl}images/team/j-osmaston.jpg`,
    imagePosition: 'object-top'
  },
  {
    name: 'Dr. med. C. Riesner',
    image: `${baseUrl}images/team/dr-riesner.jpg`,
    imagePosition: 'object-top'
  }
];

const team = ['Frau Schilling', 'Frau L. Neth', 'Frau A. Neth', 'Frau Rieger', 'Frau Rauschenbach', 'Frau Merz'];
const teamImage = `${baseUrl}images/team/praxis-team.jpg`;

const oeffnungszeiten = [
  { tag: 'Montag', zeit: '8:00 – 12:00 und 16:00 – 18:00 Uhr' },
  { tag: 'Dienstag', zeit: '8:00 – 12:00 Uhr' },
  { tag: 'Mittwoch', zeit: '8:00 – 12:00 und 16:00 – 18:00 Uhr' },
  { tag: 'Donnerstag', zeit: '8:00 – 12:00 Uhr' },
  { tag: 'Freitag', zeit: '8:00 – 12:00 und 15:00 – 16:00 Uhr' }
];

const notfall = [
  { label: 'Notarzt / Rettungsdienst', nummer: '112' },
  { label: 'Ärztlicher Bereitschaftsdienst', nummer: '116 117' },
  { label: 'Apothekenbereitschaft', nummer: '0800 0022833' },
  { label: 'Giftnotruf Baden-Württemberg', nummer: '0761 19240' }
];
---

<MainLayout>
  <header class="site-header sticky top-0 z-50 border-b border-[color:var(--line)] text-praxis-deep shadow-sm">
    <div class="section-pad flex items-center justify-between gap-4 py-3.5">
      <a href="#start" class="brand-font text-lg font-semibold tracking-tight text-praxis-deep sm:text-xl">
        MVZ Gomaringen
      </a>
      <nav class="hidden items-center gap-7 text-sm font-semibold text-praxis-ink lg:flex" aria-label="Hauptnavigation">
        <a href="#schwerpunkt" class="link-underline hover:text-praxis-accent">Schwerpunkt</a>
        <a href="#manuelle-medizin" class="link-underline hover:text-praxis-accent">Manuelle Medizin</a>
        <a href="#leistungen" class="link-underline hover:text-praxis-accent">Leistungen</a>
        <a href="#team" class="link-underline hover:text-praxis-accent">Team</a>
        <a href="#termin" class="link-underline hover:text-praxis-accent">Termin</a>
        <a href="#leitbild" class="link-underline hover:text-praxis-accent">Leitbild</a>
        <a href="#kontakt" class="link-underline hover:text-praxis-accent">Kontakt</a>
      </nav>
      <a
        href="#termin"
        class="rounded-md bg-praxis-deep px-3.5 py-2 text-sm font-semibold text-white transition hover:bg-praxis-mid"
      >
        Termin buchen
      </a>
    </div>
  </header>

  <main id="start">
    <!-- Hero: eine Komposition, Brand zuerst, vollflächig -->
    <section class="hero-atmosphere relative min-h-[88vh] overflow-hidden text-white">
      <div
        class="hero-glow pointer-events-none absolute -right-16 top-10 h-[28rem] w-[28rem] rounded-full bg-[radial-gradient(circle,rgba(215,232,235,0.22),transparent_65%)]"
        aria-hidden="true"
      ></div>
      <div
        class="pointer-events-none absolute inset-0 opacity-30"
        style="background-image: radial-gradient(rgba(255,255,255,0.18) 1px, transparent 1px); background-size: 28px 28px;"
        aria-hidden="true"
      ></div>

      <div class="section-pad relative flex min-h-[88vh] flex-col justify-center py-28 sm:py-32">
        <div class="hero-copy max-w-3xl">
          <p class="brand-font text-4xl font-semibold tracking-tight text-white sm:text-5xl lg:text-7xl">
            MVZ Gomaringen
          </p>
          <p class="mt-4 text-base font-medium text-white/85 sm:text-lg">
            der MED-GO e.G. · Hausarztpraxis Dr. Bernd Schilling
          </p>
          <h1 class="mt-8 text-2xl font-medium leading-snug text-white sm:text-3xl lg:text-[2.35rem] lg:leading-snug">
            Hausärztliche Grundversorgung · Familienmedizin – mit Nähe und Verantwortung.
          </h1>
          <p class="mt-5 text-base leading-relaxed text-white/80 sm:text-lg">
            Wir begleiten Familien in Gomaringen oft über Jahrzehnte. Manuelle Medizin bieten wir zusätzlich an.
          </p>
          <div class="mt-9 flex flex-wrap gap-3">
            <a
              href="#termin"
              class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-praxis-deep shadow-lift transition hover:bg-praxis-soft"
            >
              Online Termin anfragen
            </a>
            <a
              href="tel:+4970727031"
              class="rounded-md border border-white/40 px-5 py-3 text-sm font-semibold text-white transition hover:border-white hover:bg-white/10"
            >
              07072 / 7031
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Schwerpunkt -->
    <section id="schwerpunkt" class="border-y border-[color:var(--line)] bg-white/50">
      <div class="section-pad py-20 sm:py-24">
        <p class="text-sm font-semibold uppercase tracking-[0.14em] text-praxis-accent">Unser Schwerpunkt</p>
        <h2 class="mt-3 max-w-3xl text-3xl font-semibold text-praxis-deep sm:text-4xl">
          Hausärztliche Grundversorgung · Familienmedizin
        </h2>
        <p class="mt-5 max-w-3xl text-lg leading-relaxed text-[color:var(--text-soft)]">
          Im Mittelpunkt steht die hausärztliche Betreuung für die ganze Familie – von der Vorsorge über akute
          Beschwerden bis zur langfristigen Begleitung chronischer Erkrankungen. Wir sind Ihre erste Anlaufstelle
          im Alltag und kennen oft die Geschichte hinter dem aktuellen Anliegen.
        </p>
        <p class="mt-4 max-w-3xl leading-relaxed text-[color:var(--text-soft)]">
          Dazu kommt bei uns etwas, das viele Praxen so nicht anbieten: Manuelle Medizin als sinnvolle Ergänzung
          zur klassischen hausärztlichen Versorgung.
        </p>
      </div>
    </section>

    <!-- Manuelle Medizin – Besonderheit -->
    <section id="manuelle-medizin" class="relative overflow-hidden bg-praxis-deep text-white">
      <div
        class="pointer-events-none absolute -left-20 top-0 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(47,111,122,0.45),transparent_70%)]"
        aria-hidden="true"
      ></div>
      <div
        class="pointer-events-none absolute bottom-0 right-0 h-80 w-80 rounded-full bg-[radial-gradient(circle,rgba(196,163,90,0.2),transparent_70%)]"
        aria-hidden="true"
      ></div>

      <div class="section-pad relative grid gap-10 py-20 sm:py-24 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-praxis-highlight">
            Besonders bei uns
          </p>
          <h2 class="mt-3 text-3xl font-semibold sm:text-4xl">Manuelle Medizin</h2>
          <p class="mt-5 max-w-xl text-lg leading-relaxed text-white/80">
            Zusätzlich zur hausärztlichen Grundversorgung bieten wir Manuelle Medizin an – ein Angebot, das
            viele Praxen so nicht haben. Blockaden, Verspannungen und Funktionsstörungen behandeln wir mit
            gezielten, schonenden Techniken.
          </p>
          <p class="mt-4 max-w-xl leading-relaxed text-white/70">
            Eine Besonderheit unserer Praxis ist die Reset-Therapie. Sprechen Sie uns an, wenn Beschwerden am
            Bewegungsapparat Sie belasten – wir prüfen gemeinsam, was für Sie passt.
          </p>
        </div>

        <aside class="border border-white/15 bg-white/5 p-7 backdrop-blur-sm">
          <h3 class="text-xl font-semibold">Was Sie erwarten können</h3>
          <ul class="mt-5 space-y-4 text-white/80">
            <li class="flex gap-3">
              <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-praxis-highlight"></span>
              <span>Reset-Therapie als besondere Kompetenz unserer Praxis</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-praxis-highlight"></span>
              <span>Individuelle Untersuchung mit Blick auf Haltung, Bewegung und Beschwerdebild</span>
            </li>
          </ul>
          <a
            href="#termin"
            class="mt-8 inline-flex rounded-md bg-praxis-highlight px-4 py-2.5 text-sm font-semibold text-praxis-deep transition hover:brightness-110"
          >
            Termin anfragen
          </a>
        </aside>
      </div>
    </section>

    <!-- Leistungen -->
    <section id="leistungen" class="section-pad py-20 sm:py-24">
      <p class="text-sm font-semibold uppercase tracking-[0.14em] text-praxis-accent">Ärztliche Leistungen</p>
      <h2 class="mt-3 text-3xl font-semibold text-praxis-deep sm:text-4xl">Unser Leistungsspektrum</h2>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-[color:var(--text-soft)]">
        Von Vorsorge und Diagnostik bis zur psychosomatischen und chronischen Betreuung – ein Überblick über
        unser Spektrum in der hausärztlichen Grundversorgung.
      </p>

      <ul class="mt-10 grid gap-x-8 gap-y-3 sm:grid-cols-2 lg:grid-cols-3">
        {
          leistungen.map((item) => (
            <li class="flex items-start gap-3 border-b border-[color:var(--line)] py-3 text-[color:var(--text-soft)]">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-praxis-mid"></span>
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- Team -->
    <section id="team" class="border-y border-[color:var(--line)] bg-white/50">
      <div class="section-pad py-20 sm:py-24">
        <p class="text-sm font-semibold uppercase tracking-[0.14em] text-praxis-accent">Menschen vor Ort</p>
        <h2 class="mt-3 text-3xl font-semibold text-praxis-deep sm:text-4xl">Ärztinnen, Ärzte und Team</h2>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-[color:var(--text-soft)]">
          Ein eingespieltes Praxisteam, das zusammenhält – und Patientinnen und Patienten oft über viele Jahre
          begleitet.
        </p>

        <h3 class="mt-12 text-xl font-semibold text-praxis-deep">Ärztliche Leitung</h3>
        <ul class="mt-6 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {
            aerzte.map((arzt) => (
              <li>
                <figure>
                  <div class="aspect-[4/5] overflow-hidden bg-praxis-mist">
                    <img
                      src={arzt.image}
                      alt={`Portrait von ${arzt.name}`}
                      class={`h-full w-full object-cover ${arzt.imagePosition}`}
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                  <figcaption class="mt-4 border-l-2 border-praxis-accent pl-4 text-lg text-praxis-deep">
                    {arzt.name}
                  </figcaption>
                </figure>
              </li>
            ))
          }
        </ul>

        <div class="mt-16">
          <h3 class="text-xl font-semibold text-praxis-deep">Praxisteam</h3>
          <figure class="mt-6">
            <div class="overflow-hidden bg-praxis-mist">
              <img
                src={teamImage}
                alt="Das gesamte Praxisteam des MVZ Gomaringen vor der Praxis"
                class="h-auto w-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
            <figcaption class="mt-4 text-[color:var(--text-soft)]">
              Unser Team in Gomaringen – gemeinsam für Ihre Gesundheit.
            </figcaption>
          </figure>
          <ul class="mt-6 flex flex-wrap gap-2">
            {
              team.map((name) => (
                <li class="border border-[color:var(--line)] bg-white px-3.5 py-2 text-[color:var(--text-soft)]">
                  {name}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <!-- Termin -->
    <section id="termin" class="section-pad py-20 sm:py-24">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-praxis-accent">Terminvergabe</p>
          <h2 class="mt-3 text-3xl font-semibold text-praxis-deep sm:text-4xl">Termin vereinbaren</h2>
          <p class="mt-4 leading-relaxed text-[color:var(--text-soft)]">
            Wir sind eine Bestellpraxis – bitte vereinbaren Sie Ihren Termin immer vorab. Online können Sie
            ausgewählte Sprechstundentermine direkt buchen; telefonisch sind wir unter
            <a href="tel:+4970727031" class="font-semibold text-praxis-deep link-underline">07072 / 7031</a>
            erreichbar.
          </p>
          <p class="mt-4 leading-relaxed text-[color:var(--text-soft)]">
            Wiederholungsrezepte und Überweisungen können Sie per Telefon oder E-Mail anfordern und in der Regel
            am Folgetag abholen.
          </p>
          <p class="mt-6 border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-950">
            Hinweis für die Einrichtung: Bitte die echte S3-Embed-URL in <code class="font-mono">s3BookingUrl</code>
            eintragen.
          </p>
        </div>

        <div class="overflow-hidden border border-[color:var(--line)] bg-white shadow-soft">
          <iframe
            src={s3BookingUrl}
            title="Online-Terminvergabe"
            class="h-[560px] w-full border-0"
            loading="lazy"
            referrerpolicy="no-referrer"
          ></iframe>
        </div>
      </div>
    </section>

    <!-- Leitbild -->
    <section id="leitbild" class="section-pad py-20 sm:py-24">
      <p class="text-sm font-semibold uppercase tracking-[0.14em] text-praxis-accent">Unser Leitbild</p>
      <h2 class="mt-3 max-w-2xl text-3xl font-semibold text-praxis-deep sm:text-4xl">
        Was uns als Praxis ausmacht
      </h2>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-[color:var(--text-soft)]">
        Für alle, die mehr über unsere Haltung wissen möchten: Vier Grundsätze begleiten unsere Arbeit –
        vom ersten Gespräch bis zur langfristigen Betreuung.
      </p>

      <div class="mt-12 grid gap-10 md:grid-cols-2">
        {
          leitbild.map((item, index) => (
            <article class="border-t border-[color:var(--line)] pt-6">
              <span class="text-sm font-semibold text-praxis-accent">0{index + 1}</span>
              <h3 class="mt-2 text-2xl font-semibold text-praxis-deep">{item.title}</h3>
              <p class="mt-4 leading-relaxed text-[color:var(--text-soft)]">{item.text}</p>
            </article>
          ))
        }
      </div>
    </section>

    <!-- Kontakt & Zeiten -->
    <section id="kontakt" class="border-t border-[color:var(--line)] bg-[color:var(--bg-deep)] text-white">
      <div class="section-pad grid gap-12 py-20 sm:py-24 lg:grid-cols-3">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-praxis-highlight">Kontakt</p>
          <h2 class="mt-3 text-3xl font-semibold">So erreichen Sie uns</h2>
          <address class="mt-6 not-italic leading-relaxed text-white/80">
            MVZ Gomaringen der MED-GO e.G.<br />
            Lindenstraße 84/1<br />
            72810 Gomaringen
          </address>
          <p class="mt-5 space-y-1 text-white/80">
            <a href="tel:+4970727031" class="block font-semibold text-white link-underline">Telefon: 07072 / 7031</a>
            <span class="block">Fax: 07072 / 912690</span>
          </p>
        </div>

        <div>
          <h3 class="text-xl font-semibold">Öffnungszeiten</h3>
          <dl class="mt-5 space-y-3 text-sm">
            {
              oeffnungszeiten.map((eintrag) => (
                <div class="grid grid-cols-[7rem_1fr] gap-2 border-b border-white/10 pb-2">
                  <dt class="font-semibold text-white">{eintrag.tag}</dt>
                  <dd class="text-white/75">{eintrag.zeit}</dd>
                </div>
              ))
            }
          </dl>
          <p class="mt-4 text-sm text-white/65">Bitte immer vorab einen Termin vereinbaren.</p>
        </div>

        <div>
          <h3 class="text-xl font-semibold">Im Notfall</h3>
          <ul class="mt-5 space-y-3 text-sm">
            {
              notfall.map((eintrag) => (
                <li class="border-b border-white/10 pb-2">
                  <p class="text-white/65">{eintrag.label}</p>
                  <a
                    href={`tel:${eintrag.nummer.replace(/\s/g, '')}`}
                    class="font-semibold text-white link-underline"
                  >
                    {eintrag.nummer}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div class="border-t border-white/10">
        <div class="section-pad flex flex-col gap-3 py-6 text-sm text-white/55 sm:flex-row sm:items-center sm:justify-between">
          <p>© {new Date().getFullYear()} MVZ Gomaringen der MED-GO e.G.</p>
          <nav class="flex flex-wrap gap-x-5 gap-y-2" aria-label="Rechtliche Hinweise">
            <a href={`${baseUrl}impressum/`} class="text-white/70 link-underline hover:text-white">Impressum</a>
            <a href={`${baseUrl}datenschutz/`} class="text-white/70 link-underline hover:text-white">Datenschutz</a>
          </nav>
        </div>
      </div>
    </section>
  </main>
</MainLayout>
