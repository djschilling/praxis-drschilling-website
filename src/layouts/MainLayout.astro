---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'MVZ Gomaringen – Hausarztpraxis Dr. Bernd Schilling',
  description =
    'MVZ Gomaringen der MED-GO e.G.: Hausärztliche Grundversorgung · Familienmedizin in der Lindenstraße 84/1 – mit Manueller Medizin als besonderem Angebot.'
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const faviconHref = `${baseUrl}favicon.svg`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#164039" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
